license_path: './LICENSE'
license_label: 'mit'
license_badge: '[![License](https://img.shields.io/github/license/Kiril-Mordan/reusables)](https://github.com/Kiril-Mordan/reusables/blob/main/LICENSE)'
allowed_licenses: ['mit', 'apache-2.0', 'lgpl-3.0', 
 'bsd-3-clause', 'bsd-2-clause', '-', 'mpl-2.0']
classifiers:
- 'Development Status :: 3 - Alpha'
- 'Intended Audience :: Developers'
- 'Intended Audience :: Science/Research'
- 'Programming Language :: Python :: 3'
- 'Programming Language :: Python :: 3.10'
- 'Programming Language :: Python :: 3.11'
- 'Programming Language :: Python :: 3.12'
- 'License :: OSI Approved :: MIT License'
- 'Topic :: Scientific/Engineering'
use_commit_messages: True
add_mkdocs_site: True
pylint_threshold: 8.0
gh_pages_base_url: https://kiril-mordan.github.io/reusables
source_repo_url: https://github.com/Kiril-Mordan/reusables
source_repo_name: reusables
docker_username: kyriosskia
